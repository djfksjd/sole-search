{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "sole-search",
  "version": "0.2.0",
  "description": "한국 소상공인 지원사업(보조금·바우처, 정책자금 대출·보증, 교육·컨설팅) 전수조사 및 자격 판정 스킬 — 소상공인24·기업마당·소진공 크롤링 + 가게 프로필 기반 판정 (Korea-only).",
  "author": {
    "name": "djfksjd",
    "url": "https://github.com/djfksjd"
  },
  "homepage": "https://github.com/djfksjd/sole-search",
  "repository": "https://github.com/djfksjd/sole-search",
  "license": "MIT",
  "keywords": [
    "korea",
    "government-grants",
    "startup",
    "crawler",
    "claude-skill"
  ],
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import curl_cffi\" 2>/dev/null || pip3 install 'curl_cffi>=0.15' >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
